<?xml version="1.0" encoding="utf-8"?>
<!--
    drawable/record_button_recording.xml
    Corresponds to CSS: .record-btn.recording
    Filled red circle. The glow effect (box-shadow in CSS) is applied
    programmatically via View.setElevation() + colored shadow on API 28+,
    or via a LayerDrawable blur layer on lower APIs.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <solid android:color="@color/record_active_fill" />

    <stroke
        android:width="3dp"
        android:color="@color/record_active_fill" />

</shape>
